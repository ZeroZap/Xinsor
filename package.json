{
  "name": "@zerozap/xinsor",
  "version": "2.0.0",
  "description": "XinSor (芯感) - ZeroZap Sensor Knowledge Base & Toolchain",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "xinsor": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "dev": "node --watch src/cli.js",
    "test": "node --test tests/",
    "test:coverage": "node --test --experimental-test-coverage tests/",
    "lint": "eslint src/ tests/",
    "format": "prettier --write docs/ src/ tests/",
    "validate": "node tools/validate-docs.js",
    "generate": "node src/generator/driver.js",
    "build": "tsc --noEmit"
  },
  "keywords": [
    "sensors",
    "embedded",
    "stm32",
    "knowledge-base",
    "zerozap",
    "xinsor",
    "hardware"
  ],
  "author": "ZeroZap Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZeroZap/Xinsor.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0"
  }
}
